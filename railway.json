{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --prefix noc-qms-app && npm run build --prefix noc-qms-app"
  },
  "deploy": {
    "startCommand": "node noc-qms-app/server.cjs",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
