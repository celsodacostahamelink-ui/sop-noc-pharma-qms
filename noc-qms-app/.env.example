# NOC Pharma QMS — Environment Variables
# Copy to .env and fill in values

# ─── DATABASE ───────────────────────────────
DATABASE_URL="postgresql://noc_pharma:password@localhost:5432/noc_qms"

# ─── AUTHENTICATION ─────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── ANTHROPIC AI AGENT ─────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── FILE STORAGE ───────────────────────────
# Local: files stored in ./uploads
# S3: uncomment below for production
UPLOAD_DIR="./uploads"
# AWS_S3_BUCKET="noc-pharma-sops"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="eu-central-1"

# ─── SECURITY ───────────────────────────────
# Session timeout in seconds (default: 30min for GxP)
SESSION_MAX_AGE=1800
# Failed login lockout after N attempts
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in seconds
LOCKOUT_DURATION=900

# ─── AUDIT ──────────────────────────────────
# Audit log retention in years (EU AI Act Art.12)
AUDIT_RETENTION_YEARS=10
# Enable IP logging for audit trail
LOG_IP_ADDRESS=true
