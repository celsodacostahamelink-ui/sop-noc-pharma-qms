{
  "name": "noc-pharma-qms",
  "version": "1.0.0",
  "description": "NOC Pharma QMS — GxP Compliant Document Management System",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:compliance": "jest --testPathPattern=tests/compliance",
    "test:all": "npm run test && npm run test:e2e && npm run test:compliance",
    "validate": "npm run test:compliance -- --verbose"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "next-auth": "^4.24.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.15.0",
    "bcryptjs": "^2.4.3",
    "mammoth": "^1.8.0",
    "jszip": "^3.10.1",
    "@anthropic-ai/sdk": "^0.26.0",
    "zod": "^3.23.0",
    "lucide-react": "^0.263.1"
  },
  "devDependencies": {
    "prisma": "^5.15.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.15.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@playwright/test": "^1.45.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"
  }
}
